# Database — Neon PostgreSQL
# Use your dev branch connection strings here

# Pooled connection (used by the app and Prisma queries)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# Direct/unpooled connection (used by Prisma migrations)
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"
